{
  "name": "onersoft-web",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "@types/node": "catalog:",
    "vitest": "^4.1.5",
    "prettier": "^3.8.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.18"
  }
}
