{
  "name": "@onersoft/ui",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "prepublishOnly": "pnpm build",
    "gen:token": "tsx scripts/generate-tokens.ts",
    "lint": "pnpm gen:token && eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@onersoft/eslint-config": "workspace:*",
    "@onersoft/typescript-config": "workspace:*",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/cli": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "axe-core": "^4.11.3",
    "eslint": "^9.39.1",
    "eslint-plugin-storybook": "^10.3.5",
    "jsdom": "^29.0.2",
    "next-themes": "^0.4.6",
    "playwright": "^1.59.1",
    "pretendard": "^1.3.9",
    "rollup-preserve-directives": "^1.1.3",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.23.0",
    "typescript": "catalog:",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.1.5"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/styles/tokens.css",
    "./tokens": {
      "types": "./dist/types/tokens/index.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    },
    "./*.css": "./dist/styles/*.css",
    "./*": {
      "types": "./dist/types/components/*/index.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.74.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    }
  },
  "browserslist": [
    "Chrome >= 119",
    "Edge >= 119",
    "Firefox >= 128",
    "Safari >= 16.4",
    "iOS >= 16.4",
    "Opera >= 105"
  ]
}
